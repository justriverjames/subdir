FROM python:3.11-slim

WORKDIR /app

# Copy requirements and install
COPY webui/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy webui code
COPY webui/ .

# Expose port
EXPOSE 8480

# Run FastAPI with uvicorn
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8480"]
