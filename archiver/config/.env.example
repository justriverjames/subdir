# ============================================
# Reddit API Credentials (REQUIRED)
# ============================================
# Get credentials at: https://www.reddit.com/prefs/apps
# Create a "script" app type
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_PASSWORD=archiver_password_123
POSTGRES_DB=reddit_archiver
POSTGRES_USER=archiver
POSTGRES_PORT=5433

# ============================================
# Archival Settings
# ============================================
# Only archive subreddits with this many subscribers
MIN_SUBSCRIBERS=5000

# Max posts to fetch per subreddit (top 1000 + hot 1000 = 2000 max)
MAX_POSTS_PER_SUBREDDIT=2000

# Max comments per post
MAX_COMMENTS_PER_POST=500

# Max comment depth (how deep to follow reply chains)
MAX_COMMENT_DEPTH=5

# Filter out bot accounts
FILTER_BOTS=true

# ============================================
# Rate Limiting (Conservative)
# ============================================
REQUESTS_PER_MINUTE=60
REQUESTS_PER_10_SECONDS=10
REQUESTS_PER_SECOND=2

# ============================================
# Batch Processing
# ============================================
# Number of subreddits to process per run
BATCH_SIZE=3

# ============================================
# Optional: Import from Subdir Database
# ============================================
# Path to existing subdir SQLite database to import subreddits from
# Leave commented out to manually add subreddits instead
# SUBDIR_SQLITE_PATH=/app/data/subreddit_scanner.db

# ============================================
# System
# ============================================
LOG_LEVEL=INFO
TZ=UTC
